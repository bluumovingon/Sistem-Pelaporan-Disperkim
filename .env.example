# Security
SECRET_KEY=ganti_dengan_random_secret_key_panjang_dan_aman_di_sini
DEBUG=False

# Allowed Hosts & CSRF (Sesuaikan 'username' dengan nama akun PythonAnywhere Anda)
ALLOWED_HOSTS=username.pythonanywhere.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://username.pythonanywhere.com,http://localhost

